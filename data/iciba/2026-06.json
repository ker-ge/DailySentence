		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/a312a878f0cf9367bcbbf3f8b96e00ae.mp3"
	},
	{
		"date": "2026-06-14",
		"txt_en": "The eraser wears itself away.",
		"txt_cn": "橡皮擦消耗着自己。",
		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/c21636990538440d86ddabbde2588295.mp3"
	},
	{
		"date": "2026-06-15",
		"txt_en": "A smile is the shortest bridge.",
		"txt_cn": "微笑是最短的桥。",
		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/e12d77e03518c7a8581a3458a2ecc36a.mp3"
	},
	{
		"date": "2026-06-16",
		"txt_en": "Not seeking fleeting acclaim, But only that the echoes linger on.",
		"txt_cn": "不争一时之响，只求余音绵长。",
		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/bf816872133ace9a4e55380b8fb1ec9c.mp3"
