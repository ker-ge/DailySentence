		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/596fbe2f6e7eb2391a7454f631bfc625.mp3"
	},
	{
		"date": "2026-06-04",
		"txt_en": "Between the unread pages dwells the silence of a long hallway.",
		"txt_cn": "未读完的书页间，栖居着寂静的走廊。",
		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/31d28cb0ba24a420dca86a2c24e913a3.mp3"
	},
	{
		"date": "2026-06-05",
		"txt_en": "Wheat awns pierce the dawn. Farmers bend to pick up gold.",
		"txt_cn": "麦芒刺破晨光，农人弯腰拾起金黄。",
		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/cac7755ca80ca36da88b2bc45b4942e9.mp3"
	},
	{
		"date": "2026-06-06",
		"txt_en": "Trust time. Good things grow slowly.",
		"txt_cn": "相信时间。美好的事物需要慢慢生长。",
		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/90688cc9dacdeae779440b9a1f5feb7b.mp3"
	},
	{
		"date": "2026-06-07",
		"txt_en": "You are stronger than you imagine.",
		"txt_cn": "你比自己想象的更强大。",
		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/1065ef5dcda28b8952be1e00f47ae3e3.mp3"
	},
	{
		"date": "2026-06-08",
		"txt_en": "Go forth—the outcome will give you the answer.",
		"txt_cn": "去做吧，结果会给你答案。",
		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/14b109b1235ff141d2ab8845cd9d1908.mp3"
	},
	{
		"date": "2026-06-09",
		"txt_en": "Memory sometimes short-circuits.",
		"txt_cn": "记忆有时会短路。",
		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/4e99edb46da5453a545fcf42a91f6383.mp3"
	},
	{
		"date": "2026-06-10",
		"txt_en": "Shadows are sketches made of light.",
		"txt_cn": "影子是光做的素描。",
		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/11ce252ff8847af1499d536f140d9331.mp3"
	},
	{
		"date": "2026-06-11",
		"txt_en": "The door closed on the story just now.",
		"txt_cn": "门合上了刚才的故事。",
		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/f0c0c1a4df58093e415379a8a0c6d657.mp3"
	},
	{
		"date": "2026-06-12",
		"txt_en": "The scent of green lime cuts through the stifling air.",
