		"readmp3": "https://staticedu-wps-cache.iciba.com/audio/806c49beacbd05f5683a421c14f2ceff.mp3"
	},
	{
		"date": "2026-06-13",
		"txt_en": "You miss 100% of the shots you don’t take.",
